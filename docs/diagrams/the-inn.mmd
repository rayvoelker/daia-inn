    classDef spouse fill:#be185d,stroke:#9d174d,color:#fff
    classDef container fill:#1e3a5f,stroke:#2563eb,color:#dbeafe
    classDef mcp fill:#2563eb,stroke:#1e40af,color:#fff
    classDef resource fill:#10b981,stroke:#059669,color:#fff
    classDef tool fill:#f59e0b,stroke:#d97706,color:#fff
    classDef code fill:#6b7280,stroke:#4b5563,color:#fff
    classDef model fill:#10b981,stroke:#059669,color:#fff
    classDef storage fill:#f3f4f6,stroke:#9ca3af,color:#1a1a1a
    classDef external fill:#8b5cf6,stroke:#7c3aed,color:#fff
    classDef hw fill:#dc2626,stroke:#b91c1c,color:#fff
    classDef future fill:#374151,stroke:#6b7280,color:#9ca3af,stroke-dasharray: 5 5

    class SPOUSE_TIMER,SPOUSE_SVC spouse
    class MCP mcp
    class HEALTH resource
    class ROSTER,LEDGER_R future
    class COOK_TOOL,DISPATCH future
    class SERVER,HEALTH_MOD,SYSTEM_MOD,OLLAMA_MOD code
    class LINE_COOK,SCOUT model
    class LEDGER_VOL,OLLAMA_VOL storage
    class ANTHROPIC,HUMAN,TAILSCALE external
    class GPU,RAM hw
    class INNKEEPER,CLAUDE_MD,API_KEY container
