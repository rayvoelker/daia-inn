---
title: "The Inn — Physical Architecture"
---
%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#2563eb', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1e40af', 'lineColor': '#6b7280', 'secondaryColor': '#f59e0b', 'tertiaryColor': '#10b981', 'background': '#fafafa', 'fontFamily': 'system-ui', 'fontSize': '14px'}}}%%

flowchart TB

    %% ═══════════════════════════════════════
    %% HOST LAYER — systemd (the spouse)
    %% ═══════════════════════════════════════
    subgraph HOST["daia-ts host (systemd)"]
        direction TB

        subgraph SPOUSE_LAYER["The Innkeeper's Spouse"]
            direction LR
            SPOUSE_TIMER["innkeeper-spouse.timer\nOnUnitActiveSec=30s"]
            SPOUSE_SVC["innkeeper-spouse.service\n\nChecks innkeeper logs\nKills on stall (120s)\nEnforces budget\nWrites intervention records"]
            SPOUSE_TIMER -->|triggers| SPOUSE_SVC
        end

        %% ═══════════════════════════════════════
        %% DOCKER LAYER
        %% ═══════════════════════════════════════
        subgraph COMPOSE["docker compose"]
            direction TB

            %% ─── The Innkeeper ───
            subgraph INNKEEPER_BOX["innkeeper container"]
                direction TB
                INNKEEPER["claude -p\n(per-task invocation)\n\nReads ledger\nClassifies task\nDispatches workers\nAccumulates context\nHands narrative to scribe\nExits when done"]
                CLAUDE_MD["CLAUDE.md\n(the inn model\nas markdown)"]
                API_KEY["ANTHROPIC_API_KEY"]
            end

            %% ─── The Inn (MCP Server) ───
            subgraph INN_BOX["inn container :3001"]
                direction TB
                MCP["MCP Server\n(FastMCP, Python)"]

                subgraph RESOURCES["Resources (read-only windows)"]
                    direction LR
                    HEALTH["inn://health\n(v0.1 - live)"]
                    ROSTER["inn://roster\n(future)"]
                    LEDGER_R["inn://ledger\n(future)"]
                end

                subgraph TOOLS["Tools (actions)"]
                    direction LR
                    COOK_TOOL["inn.cook()\n(future)"]
                    DISPATCH["inn.dispatch()\n(future)"]
                end

                subgraph CODE["Source modules"]
                    direction LR
                    SERVER["server.py\n(composition)"]
                    HEALTH_MOD["health.py\n(parsing)"]
                    SYSTEM_MOD["system.py\n(GPU/RAM)"]
                    OLLAMA_MOD["ollama.py\n(I/O client)"]
                end
            end

            %% ─── The Oven ───
            subgraph OVEN_BOX["ollama container :11434"]
                direction TB
                OLLAMA["Ollama API"]

                subgraph MODELS["Loaded Models"]
                    direction LR
                    LINE_COOK["gemma4:26b\n(line cook)\nGPU, 50 tok/s"]
                    SCOUT["gemma4:e4b-cpu\n(scout)\nCPU, 13 tok/s"]
                end
            end

            %% ─── Shared Storage ───
            subgraph STORAGE["Shared Volumes"]
                direction LR
                LEDGER_VOL[("Ledger\n(task records)")]
                OLLAMA_VOL[("ollama_data\n(model weights)")]
            end
        end
    end

    %% ═══════════════════════════════════════
    %% EXTERNAL — Clients & APIs
    %% ═══════════════════════════════════════
    subgraph EXTERNAL["External"]
        direction LR
        ANTHROPIC["Anthropic API\n(api.anthropic.com)\n\nOpus / Sonnet / Haiku"]
        HUMAN["Human\n(Claude Code session\non laptop)"]
        TAILSCALE["Tailscale\n(daia.tailnet)"]
    end

    %% ═══════════════════════════════════════
    %% HARDWARE
    %% ═══════════════════════════════════════
    subgraph HW["Hardware"]
        direction LR
        GPU["RTX 4090\n24GB VRAM"]
        RAM["124GB RAM\n32 cores"]
    end

    %% ═══════════════════════════════════════
    %% CONNECTIONS
    %% ═══════════════════════════════════════

    %% Spouse watches innkeeper
    SPOUSE_SVC -->|"docker logs / restart"| INNKEEPER_BOX

    %% Innkeeper connects to inn via MCP
    INNKEEPER -->|"MCP client\n(reads resources,\ncalls tools)"| MCP

    %% Innkeeper calls Anthropic API
    INNKEEPER -->|"API calls\n(Opus for decisions)"| ANTHROPIC

    %% Inn queries Ollama
    OLLAMA_MOD -->|"HTTP\n/api/ps, /api/version"| OLLAMA

    %% Inn reads system stats
    SYSTEM_MOD -->|"nvidia-smi\n/proc/meminfo"| HW

    %% Human connects via Tailscale
    HUMAN -->|"MCP client\n(via Tailscale)"| TAILSCALE
    TAILSCALE --> MCP

    %% Models use hardware
    LINE_COOK -.-> GPU
    SCOUT -.-> RAM

    %% Storage connections
    INNKEEPER -->|"reads/writes"| LEDGER_VOL
    OLLAMA -->|"model weights"| OLLAMA_VOL

